###############################################################################
# SOC Platform — Environment Variables
# مركز العمليات الأمنية — متغيرات البيئة
#
# Copy this file to .env and customise before deployment:
#   cp .env.example .env
#
# WARNING: Never commit .env to version control!
# تحذير: لا ترفع ملف .env إلى نظام التحكم بالإصدارات
###############################################################################

# =============================================================================
# GENERAL / عام
# =============================================================================

# Host IP address (used for service bindings and inter-service communication)
# عنوان IP للجهاز المضيف
HOST_IP=192.168.1.100

# Project name prefix for Docker containers
COMPOSE_PROJECT_NAME=soc

# Timezone / المنطقة الزمنية
TZ=Asia/Riyadh

# =============================================================================
# OPENSEARCH / محرك البحث
# =============================================================================

OPENSEARCH_VERSION=2.17.0
OPENSEARCH_INITIAL_ADMIN_PASSWORD=Ch@ngeMe_OpenSearch_2024!
OPENSEARCH_JAVA_OPTS=-Xms2g -Xmx2g
OPENSEARCH_NODE1_PORT=9200
OPENSEARCH_NODE2_PORT=9201
OPENSEARCH_DASHBOARDS_PORT=5601

# Disable security plugin for initial setup (set to "true" for production)
OPENSEARCH_SECURITY_ENABLED=false

# =============================================================================
# WAZUH / وازه
# =============================================================================

WAZUH_VERSION=4.9.2
WAZUH_MANAGER_PORT=1514
WAZUH_REGISTRATION_PORT=1515
WAZUH_API_PORT=55000
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=Ch@ngeMe_Wazuh_API_2024!
WAZUH_DASHBOARD_PORT=443
WAZUH_DASHBOARD_USER=admin
WAZUH_DASHBOARD_PASSWORD=Ch@ngeMe_Wazuh_Dash_2024!

# =============================================================================
# SURICATA / سوريكاتا
# =============================================================================

# Network interface for packet capture (change to your SPAN/mirror interface)
# واجهة الشبكة لالتقاط الحزم
SURICATA_INTERFACE=eth0
SURICATA_HOME_NET=192.168.0.0/16

# =============================================================================
# ZEEK / زيك
# =============================================================================

ZEEK_INTERFACE=eth0

# =============================================================================
# KAFKA / كافكا
# =============================================================================

KAFKA_VERSION=7.5.0
KAFKA_BROKER_PORT=9092
KAFKA_BROKER_ID=1
KAFKA_HEAP_OPTS=-Xms512m -Xmx1g
ZOOKEEPER_PORT=2181

# =============================================================================
# MISP / منصة مشاركة المعلومات
# =============================================================================

MISP_PORT=8443
MISP_ADMIN_EMAIL=admin@admin.test
MISP_ADMIN_PASSWORD=Ch@ngeMe_MISP_2024!
MISP_BASEURL=https://localhost:8443
MYSQL_MISP_PASSWORD=Ch@ngeMe_MISP_MySQL_2024!

# =============================================================================
# OPENCTI / منصة الاستخبارات السيبرانية
# =============================================================================

OPENCTI_VERSION=6.3.0
OPENCTI_PORT=8080
OPENCTI_ADMIN_EMAIL=admin@opencti.io
OPENCTI_ADMIN_PASSWORD=Ch@ngeMe_OpenCTI_2024!
OPENCTI_ADMIN_TOKEN=changeme-opencti-admin-token-uuid-here
OPENCTI_HEALTHCHECK_KEY=changeme-healthcheck-key

# Redis for OpenCTI
REDIS_OPENCTI_PORT=6380

# RabbitMQ for OpenCTI
RABBITMQ_DEFAULT_USER=opencti
RABBITMQ_DEFAULT_PASS=Ch@ngeMe_RabbitMQ_2024!
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# Elasticsearch for OpenCTI (separate from OpenSearch)
ELASTIC_OPENCTI_PORT=9210

# =============================================================================
# INTELOWL / إنتل أول
# =============================================================================

INTELOWL_PORT=8085

# =============================================================================
# DFIR-IRIS / إدارة الحوادث
# =============================================================================

IRIS_PORT=4433
IRIS_ADMIN_PASSWORD=Ch@ngeMe_IRIS_2024!
IRIS_SECRET_KEY=changeme-iris-secret-key-random-string

# =============================================================================
# SHUFFLE (SOAR) / أتمتة الاستجابة
# =============================================================================

SHUFFLE_BACKEND_PORT=5001
SHUFFLE_FRONTEND_PORT=3001
SHUFFLE_ORBORUS_PORT=5002
SHUFFLE_APP_HOTLOAD_FOLDER=./data/shuffle/apps
SHUFFLE_FILE_LOCATION=./data/shuffle/files

# =============================================================================
# GRAFANA / لوحة المراقبة
# =============================================================================

GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=Ch@ngeMe_Grafana_2024!

# =============================================================================
# PROMETHEUS / بروميثيوس
# =============================================================================

PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=30d

# =============================================================================
# UPTIME KUMA / مراقب الجهوزية
# =============================================================================

UPTIME_KUMA_PORT=3002

# =============================================================================
# CAPEv2 (SANDBOX) / صندوق الرمل
# =============================================================================

CAPEV2_WEB_PORT=8000

# =============================================================================
# OPENVAS / GREENBONE / فحص الثغرات
# =============================================================================

OPENVAS_PORT=9392
OPENVAS_ADMIN_PASSWORD=Ch@ngeMe_OpenVAS_2024!

# =============================================================================
# KEYCLOAK / إدارة الهوية
# =============================================================================

KEYCLOAK_PORT=8180
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=Ch@ngeMe_Keycloak_2024!
KC_DB_PASSWORD=Ch@ngeMe_KC_DB_2024!

# =============================================================================
# T-POT CE (HONEYPOT) / مصيدة
# =============================================================================

TPOT_WEB_PORT=64297

# =============================================================================
# OLLAMA (AI/LLM) / الذكاء الاصطناعي
# =============================================================================

OLLAMA_PORT=11434
OLLAMA_MODELS=mistral,codellama,llama3

# =============================================================================
# REDIS (AI AGENT MESSAGE QUEUE) / قائمة رسائل الوكلاء
# =============================================================================

REDIS_AI_PORT=6379
REDIS_AI_PASSWORD=Ch@ngeMe_Redis_AI_2024!

# =============================================================================
# AI AGENTS / وكلاء الذكاء الاصطناعي
# =============================================================================

AI_AGENTS_LOG_LEVEL=INFO
AI_AGENTS_WORKERS=4
AI_AGENTS_OLLAMA_MODEL=mistral

# =============================================================================
# TOOL VERSIONS (PINNED) / إصدارات الأدوات المثبتة
# =============================================================================

OLLAMA_VERSION=0.3.1
INTELOWL_VERSION=5.1.0
IRIS_VERSION=v2.4.9
SHUFFLE_VERSION=1.3.0
PROMETHEUS_VERSION=v2.53.1
GRAFANA_VERSION=11.1.0
UPTIME_KUMA_VERSION=1.23.13
NODE_EXPORTER_VERSION=v1.8.2
SURICATA_VERSION=7.0.6
ZEEK_VERSION=7.0.0
VECTOR_VERSION=0.40.0-alpine
GREENBONE_VERSION=22.4.1
KEYCLOAK_VERSION=25.0.2
TPOT_VERSION=24.04

# =============================================================================
# ZERO TRUST & WORKSPACES / الثقة المعدومة والفقاعات
# =============================================================================

WEBTOP_VERSION=ubuntu-xfce
WEBTOP_PORT=3000
CLOUDFLARED_VERSION=latest
NETBIRD_VERSION=latest

# =============================================================================
# RESOURCE LIMITS / حدود الموارد
# =============================================================================

# OpenSearch memory limits
OPENSEARCH_MEM_LIMIT=4g
OPENSEARCH_MEM_RESERVATION=2g

# Wazuh memory limits
WAZUH_MEM_LIMIT=2g

# Kafka memory limits
KAFKA_MEM_LIMIT=2g

# Grafana memory limits
GRAFANA_MEM_LIMIT=512m

# Ollama memory limits (set high if using GPU)
OLLAMA_MEM_LIMIT=8g
